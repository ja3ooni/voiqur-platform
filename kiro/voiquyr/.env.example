# ============================================================
# EUVoice AI Platform — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Application ---
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENABLE_DOCS=true

# --- JWT Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-with-secrets-token-hex-32

# --- PostgreSQL ---
# Full DSN including port. Database must exist before startup.
DATABASE_URL=postgresql://user:password@localhost:5432/euvoice

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Mistral AI (LLM — EU-based provider) ---
# From: https://console.mistral.ai/ -> API Keys
MISTRAL_API_KEY=your-mistral-api-key

# --- Deepgram (STT) ---
# From: https://console.deepgram.com/ -> API Keys
DEEPGRAM_API_KEY=your-deepgram-api-key

# --- ElevenLabs (TTS) ---
# From: https://elevenlabs.io/ -> Profile -> API Key
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# --- Twilio (Telephony) ---
# From: https://console.twilio.com/ -> Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# --- Stripe (Billing) ---
# From: https://dashboard.stripe.com/ -> Developers -> API Keys
STRIPE_API_KEY=sk_test_your-stripe-api-key

# --- Webhooks ---
MAX_CONCURRENT_WEBHOOKS=100
WEBHOOK_TIMEOUT=30
WEBHOOK_MAX_RETRIES=5
WEBHOOK_CLEANUP_DAYS=30
